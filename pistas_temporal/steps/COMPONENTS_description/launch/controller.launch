<launch>

<rosparam file="$(find COMPONENTS_description)/launch/controller.yaml" command="load"/>
<node name="controller_spawner" pkg="controller_manager" type="spawner" respawn="false" output="screen" ns="COMPONENTS" args="Cylindrical 1_position_controller Cylindrical 3_position_controller Cylindrical 5_position_controller Cylindrical 7_position_controller Cylindrical 9_position_controller joint_state_controller "/>
<node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" respawn="false" output="screen">
  <remap from="/joint_states" to="/COMPONENTS/joint_states"/>
</node>

</launch>