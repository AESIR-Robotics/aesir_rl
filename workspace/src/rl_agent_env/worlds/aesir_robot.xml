<!--
  aesir_robot.xml  —  FRAGMENTO MJCF (sin <mujoco> wrapper).
  Incluido por los archivos de mundo vía <include file="aesir_robot.xml"/>.
  El <compiler meshdir="meshes"/> del mundo padre resuelve todas las rutas
  de malla relativas a su propio directorio.
-->

<contact>
  <exclude body1="footprint_link" body2="flipper_1_link"/>
  <exclude body1="footprint_link" body2="flipper_2_link"/>
  <exclude body1="footprint_link" body2="flipper_3_link"/>
  <exclude body1="footprint_link" body2="flipper_4_link"/>
</contact>

<asset>
  <!-- Rutas sin prefijo meshes/ — resueltas por meshdir del mundo padre -->
  <mesh name="base_link"   file="base_link.stl"   scale="0.001 0.001 0.001"/>
  <mesh name="tracked_1"   file="tracked_1.stl"   scale="0.001 0.001 0.001"/>
  <mesh name="tracked_2"   file="tracked_2.stl"   scale="0.001 0.001 0.001"/>
  <mesh name="flipper_1_1" file="flipper_1_1.stl" scale="0.001 0.001 0.001"/>
  <mesh name="flipper_4_1" file="flipper_4_1.stl" scale="0.001 0.001 0.001"/>
  <mesh name="flipper_3_1" file="flipper_3_1.stl" scale="0.001 0.001 0.001"/>
  <mesh name="flipper_2_1" file="flipper_2_1.stl" scale="0.001 0.001 0.001"/>
  <mesh name="lidar"       file="lidar.stl"       scale="0.001 0.001 0.001"/>
</asset>

<worldbody>
  <!-- ================ ROBOT AESIR ================ -->
  <body name="footprint_link" pos="0 0 0.1">
    <freejoint name="base_freejoint"/>
    <inertial pos="0 0 0.06" mass="25.0" diaginertia="1.2 1.6 2.7"/>

    <geom pos="0 0.55 0" type="mesh" rgba="0.75 0.75 0.75 1" mesh="base_link"  contype="0" conaffinity="0"/>
    <geom pos="0 0.55 0" type="mesh" rgba="0.75 0.75 0.75 1" mesh="tracked_1"  contype="0" conaffinity="0"/>
    <geom pos="0 0.562 0" type="mesh" rgba="0.75 0.75 0.75 1" mesh="tracked_2" contype="0" conaffinity="0"/>
    <geom size="0.06 0.07915" pos="0.12 0 0.13915" type="cylinder" rgba="0.2 0.2 0.2 1"/>

    <!-- LIDAR rotatorio — 7 rayos verticales, gira sobre eje Z -->
    <body name="sensor_lidar" pos="0.32 0 0.105" euler="0 0.7854 0">
      <joint name="lidar_spin" type="hinge" axis="0 0 1" damping="0.1" armature="0.01"/>
      <geom type="mesh" rgba="0.2 0.2 0.2 1" mesh="lidar" contype="0" conaffinity="0"/>
      <site name="ray_0" pos="0.03 0 0.037" euler="0 0      0" type="sphere" size="0.005"/>
      <site name="ray_1" pos="0.03 0 0.037" euler="0 0.2793 0" type="sphere" size="0.005"/>
      <site name="ray_2" pos="0.03 0 0.037" euler="0 0.5585 0" type="sphere" size="0.005"/>
      <site name="ray_3" pos="0.03 0 0.037" euler="0 0.8378 0" type="sphere" size="0.005"/>
      <site name="ray_4" pos="0.03 0 0.037" euler="0 1.1170 0" type="sphere" size="0.005"/>
      <site name="ray_5" pos="0.03 0 0.037" euler="0 1.3963 0" type="sphere" size="0.005"/>
      <site name="ray_6" pos="0.03 0 0.037" euler="0 1.6755 0" type="sphere" size="0.005"/>
    </body>

    <!-- Cámara OAK-D frontal -->
    <geom size="0.01 0.05 0.015" pos="0.257 0 0.19" type="box" rgba="0.7 0.7 0.7 1" contype="0" conaffinity="0"/>
    <body name="camera_oakd_link" pos="0.257 0 0.19">
      <camera name="cam_oakd" pos="0 0 0" quat="0.5 -0.5 -0.5 0.5" fovy="69"/>
    </body>

    <!-- Cámara trasera (cuerpo visual omitido — logitech_c920.stl no disponible) -->
    <body name="camera_back_link" pos="-0.34 0.027 -0.02">
      <geom size="0.04 0.025 0.015" type="box" rgba="0.2 0.2 0.2 1" contype="0" conaffinity="0"/>
      <camera name="cam_back" pos="0.02 -0.027 0.175" euler="1.5708 1.5708 3.14159" fovy="78"/>
    </body>

    <!-- FLIPPERS -->
    <body name="flipper_1_link" pos="-0.24 -0.256 0.06">
      <inertial pos="0 0.00355409 0.15154" quat="0.707092 -0.00452931 0.00452931 0.707092"
                mass="3.74207" diaginertia="0.0729765 0.065573 0.00896149"/>
      <joint name="flipper_joint_1" axis="0 -1 0" damping="2.0" armature="0.05"/>
      <geom pos="0.24 0.826 -0.06" type="mesh" rgba="0.75 0.75 0.75 1" mesh="flipper_1_1" contype="0" conaffinity="0"/>
      <body name="wheel_flip1_back"  pos="0 0 0.18">
        <joint name="drive_flip1_back"  type="hinge" axis="0 1 0" damping="0.1" armature="0.05"/>
        <geom type="cylinder" size="0.07 0.02" quat="0.707107 0.707107 0 0" rgba="1 0 0 0.5" friction="1.5 0.005 0.0001"/>
      </body>
      <body name="wheel_flip1_front" pos="0 0 0.35">
        <joint name="drive_flip1_front" type="hinge" axis="0 1 0" damping="0.1" armature="0.05"/>
        <geom type="cylinder" size="0.05 0.02" quat="0.707107 0.707107 0 0" rgba="1 0 0 0.5" friction="1.5 0.005 0.0001"/>
      </body>
    </body>

    <body name="flipper_2_link" pos="0.24 -0.256 0.06">
      <inertial pos="0 -0.00355409 0.15154" quat="0.707092 0.00452931 -0.00452931 0.707092"
                mass="3.74207" diaginertia="0.0729765 0.065573 0.00896149"/>
      <joint name="flipper_joint_2" axis="0 -1 0" damping="2.0" armature="0.05"/>
      <geom pos="-0.24 0.826 -0.06" type="mesh" rgba="0.75 0.75 0.75 1" mesh="flipper_2_1" contype="0" conaffinity="0"/>
      <body name="wheel_flip2_back"  pos="0 0 0.18">
        <joint name="drive_flip2_back"  type="hinge" axis="0 1 0" damping="0.1" armature="0.05"/>
        <geom type="cylinder" size="0.07 0.02" quat="0.707107 0.707107 0 0" rgba="1 0 0 0.5" friction="1.5 0.005 0.0001"/>
      </body>
      <body name="wheel_flip2_front" pos="0 0 0.35">
        <joint name="drive_flip2_front" type="hinge" axis="0 1 0" damping="0.1" armature="0.05"/>
        <geom type="cylinder" size="0.05 0.02" quat="0.707107 0.707107 0 0" rgba="1 0 0 0.5" friction="1.5 0.005 0.0001"/>
      </body>
    </body>

    <body name="flipper_3_link" pos="0.24 0.256 0.06">
      <inertial pos="0 -0.00355409 0.15154" quat="0.707092 0.00452931 -0.00452931 0.707092"
                mass="3.74207" diaginertia="0.0729765 0.065573 0.00896149"/>
      <joint name="flipper_joint_3" axis="0 1 0" damping="2.0" armature="0.05"/>
      <geom pos="0.24 0.276 -0.06" type="mesh" rgba="0.75 0.75 0.75 1" mesh="flipper_3_1" contype="0" conaffinity="0"/>
      <body name="wheel_flip3_back"  pos="0 0 0.18">
        <joint name="drive_flip3_back"  type="hinge" axis="0 1 0" damping="0.1" armature="0.05"/>
        <geom type="cylinder" size="0.07 0.02" quat="0.707107 0.707107 0 0" rgba="1 0 0 0.5" friction="1.5 0.005 0.0001"/>
      </body>
      <body name="wheel_flip3_front" pos="0 0 0.35">
        <joint name="drive_flip3_front" type="hinge" axis="0 1 0" damping="0.1" armature="0.05"/>
        <geom type="cylinder" size="0.05 0.02" quat="0.707107 0.707107 0 0" rgba="1 0 0 0.5" friction="1.5 0.005 0.0001"/>
      </body>
    </body>

    <body name="flipper_4_link" pos="-0.24 0.256 0.06">
      <inertial pos="0 -0.00355409 0.15154" quat="0.707092 0.00452931 -0.00452931 0.707092"
                mass="3.74207" diaginertia="0.0729765 0.065573 0.00896149"/>
      <joint name="flipper_joint_4" axis="0 1 0" damping="2.0" armature="0.05"/>
      <geom pos="-0.24 0.276 -0.06" type="mesh" rgba="0.75 0.75 0.75 1" mesh="flipper_4_1" contype="0" conaffinity="0"/>
      <body name="wheel_flip4_back"  pos="0 0 0.18">
        <joint name="drive_flip4_back"  type="hinge" axis="0 1 0" damping="0.1" armature="0.05"/>
        <geom type="cylinder" size="0.07 0.02" quat="0.707107 0.707107 0 0" rgba="1 0 0 0.5" friction="1.5 0.005 0.0001"/>
      </body>
      <body name="wheel_flip4_front" pos="0 0 0.35">
        <joint name="drive_flip4_front" type="hinge" axis="0 1 0" damping="0.1" armature="0.05"/>
        <geom type="cylinder" size="0.05 0.02" quat="0.707107 0.707107 0 0" rgba="1 0 0 0.5" friction="1.5 0.005 0.0001"/>
      </body>
    </body>

    <!-- BRAZO 6-DOF -->
    <body name="link_1" pos="0.12 0 0.2183">
      <inertial pos="0 0 0" mass="1.5" diaginertia="0.01 0.01 0.005"/>
      <joint name="joint_1" axis="0 0 1" range="-3.14 3.14" actuatorfrcrange="-150 150" damping="20.0" armature="0.05"/>
      <geom size="0.05 0.05015" pos="0 0.05015 0" quat="0.707107 0.707107 0 0" type="cylinder" rgba="0.7 0.7 0.7 1"/>
      <body name="link_2" pos="0 0.1003 0">
        <inertial pos="0 0 0" mass="1.5" diaginertia="0.01 0.01 0.005"/>
        <joint name="joint_2" axis="0 1 0" range="-3.14 3.14" actuatorfrcrange="-150 150" damping="20.0" armature="0.05"/>
        <geom size="0.035 0.17658" pos="0.17658 0 0" quat="0.707107 0 0.707107 0" type="cylinder" rgba="1 0.4 0 1"/>
        <geom size="0.04 0.05015" pos="0.35316 -0.05015 0" quat="0.707107 0.707107 0 0" type="cylinder" rgba="0.2 0.2 0.2 1"/>
        <body name="link_3" pos="0.35316 -0.1003 0">
          <inertial pos="0 0 0" mass="1.5" diaginertia="0.01 0.01 0.005"/>
          <joint name="joint_3" axis="0 1 0" range="-3.14 3.14" actuatorfrcrange="-150 150" damping="20.0" armature="0.05"/>
          <geom size="0.03 0.233" pos="0.233 0 0" quat="0.707107 0 0.707107 0" type="cylinder" rgba="0.7 0.7 0.7 1"/>
          <geom size="0.03 0.037" pos="0.466 0.037 0" quat="0.707107 0.707107 0 0" type="cylinder" rgba="1 0.4 0 1"/>
          <body name="link_4" pos="0.466 0.074 0">
            <inertial pos="0 0 0" mass="1.5" diaginertia="0.01 0.01 0.005"/>
            <joint name="joint_4" axis="0 1 0" range="-3.14 3.14" actuatorfrcrange="-50 50" damping="20.0" armature="0.05"/>
            <geom size="0.025 0.04675" pos="0.04675 0 0" quat="0.707107 0 0.707107 0" type="cylinder" rgba="0.2 0.2 0.2 1"/>
            <body name="link_5" pos="0.0935 0 0">
              <inertial pos="0 0 0" mass="1.5" diaginertia="0.01 0.01 0.005"/>
              <joint name="joint_5" axis="1 0 0" range="-3.14 3.14" actuatorfrcrange="-50 50" damping="20.0" armature="0.05"/>
              <geom size="0.025 0.04675" pos="0 0.04675 0" quat="0.707107 0.707107 0 0" type="cylinder" rgba="0.7 0.7 0.7 1"/>
              <body name="link_6" pos="0 0.0935 0">
                <inertial pos="0 0 0.00162" mass="1.85" diaginertia="0.0112 0.0112 0.006"/>
                <joint name="joint_6" axis="0 1 0" range="-3.14 3.14" actuatorfrcrange="-50 50" damping="20.0" armature="0.05"/>
                <geom size="0.04 0.02 0.03" pos="0 0.02 0" type="box" rgba="0.2 0.2 0.2 1"/>
                <!-- Cámara de la garra (cuerpo visual omitido) -->
                <body name="logitech_gripper_assembly" pos="0.05 0.00466 -0.1439" euler="-0.1745 0 -1.5708">
                  <geom size="0.04 0.015 0.025" type="box" rgba="0.2 0.2 0.2 1" contype="0" conaffinity="0"/>
                  <camera name="cam_gripper" pos="0.00466 -0.05 0.2" euler="-1.5708 1.5708 0.1745" fovy="78"/>
                </body>
                <body name="left_finger_link" pos="-0.035 0.04 0">
                  <inertial pos="0 0 0" mass="0.05" diaginertia="0.0001 0.0001 0.0001"/>
                  <joint name="left_finger_joint" axis="1 0 0" type="slide" range="0 0.03" actuatorfrcrange="-50 50" damping="20.0" armature="0.05"/>
                  <geom size="0.005 0.04 0.01" pos="0 0.04 0" type="box" rgba="1 0.4 0 1"/>
                </body>
                <body name="right_finger_link" pos="0.035 0.04 0">
                  <inertial pos="0 0 0" mass="0.05" diaginertia="0.0001 0.0001 0.0001"/>
                  <joint name="right_finger_joint" axis="-1 0 0" type="slide" range="0 0.03" actuatorfrcrange="-50 50" damping="20.0" armature="0.05"/>
                  <geom size="0.005 0.04 0.01" pos="0 0.04 0" type="box" rgba="1 0.4 0 1"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!-- RUEDAS MOTRICES IZQUIERDA (drive_l_2 = rueda maestra para diff_drive) -->
    <body name="wheel_l_1" pos="0.24  0.18 0.06">
      <inertial pos="0 0 0" mass="0.8" diaginertia="0.01 0.01 0.01"/>
      <joint name="drive_l_1" type="hinge" axis="0 1 0"/>
      <geom type="cylinder" size="0.1 0.1"   quat="0.707107 0.707107 0 0" rgba="0.1 0.1 0.1 1" friction="1.5 0.005 0.0001"/>
    </body>
    <body name="wheel_l_2" pos="0     0.165 0.06">
      <inertial pos="0 0 0" mass="0.8" diaginertia="0.01 0.01 0.01"/>
      <joint name="drive_l_2" type="hinge" axis="0 1 0"/>
      <geom type="cylinder" size="0.1 0.085" quat="0.707107 0.707107 0 0" rgba="0.1 0.1 0.1 1" friction="1.5 0.005 0.0001"/>
    </body>
    <body name="wheel_l_3" pos="-0.24 0.18 0.06">
      <inertial pos="0 0 0" mass="0.8" diaginertia="0.01 0.01 0.01"/>
      <joint name="drive_l_3" type="hinge" axis="0 1 0"/>
      <geom type="cylinder" size="0.1 0.085" quat="0.707107 0.707107 0 0" rgba="0.1 0.1 0.1 1" friction="1.5 0.005 0.0001"/>
    </body>

    <!-- RUEDAS MOTRICES DERECHA (drive_r_2 = rueda maestra para diff_drive) -->
    <body name="wheel_r_1" pos="0.24  -0.18 0.06">
      <inertial pos="0 0 0" mass="0.8" diaginertia="0.01 0.01 0.01"/>
      <joint name="drive_r_1" type="hinge" axis="0 1 0"/>
      <geom type="cylinder" size="0.1 0.1"   quat="0.707107 0.707107 0 0" rgba="0.1 0.1 0.1 1" friction="1.5 0.005 0.0001"/>
    </body>
    <body name="wheel_r_2" pos="0     -0.165 0.06">
      <inertial pos="0 0 0" mass="0.8" diaginertia="0.01 0.01 0.01"/>
      <joint name="drive_r_2" type="hinge" axis="0 1 0"/>
      <geom type="cylinder" size="0.1 0.085" quat="0.707107 0.707107 0 0" rgba="0.1 0.1 0.1 1" friction="1.5 0.005 0.0001"/>
    </body>
    <body name="wheel_r_3" pos="-0.24 -0.18 0.06">
      <inertial pos="0 0 0" mass="0.8" diaginertia="0.01 0.01 0.01"/>
      <joint name="drive_r_3" type="hinge" axis="0 1 0"/>
      <geom type="cylinder" size="0.1 0.085" quat="0.707107 0.707107 0 0" rgba="0.1 0.1 0.1 1" friction="1.5 0.005 0.0001"/>
    </body>

  </body><!-- /footprint_link -->
</worldbody>

<actuator>
  <!-- FLIPPERS — control de posición -->
  <position name="pos_flipper_1" joint="flipper_joint_1" kp="200" ctrlrange="-3.1416 3.1416"/>
  <position name="pos_flipper_2" joint="flipper_joint_2" kp="200" ctrlrange="-3.1416 3.1416"/>
  <position name="pos_flipper_3" joint="flipper_joint_3" kp="200" ctrlrange="-3.1416 3.1416"/>
  <position name="pos_flipper_4" joint="flipper_joint_4" kp="200" ctrlrange="-3.1416 3.1416"/>

  <!-- BRAZO 6-DOF — control de posición (sobreescrito por joint_group_velocity_controller en ROS) -->
  <position name="pos_joint_1" joint="joint_1" kp="200" ctrlrange="-3.1416 3.1416"/>
  <position name="pos_joint_2" joint="joint_2" kp="200" ctrlrange="-3.1416 3.1416"/>
  <position name="pos_joint_3" joint="joint_3" kp="200" ctrlrange="-3.1416 3.1416"/>
  <position name="pos_joint_4" joint="joint_4" kp="200" ctrlrange="-3.1416 3.1416"/>
  <position name="pos_joint_5" joint="joint_5" kp="200" ctrlrange="-3.1416 3.1416"/>
  <position name="pos_joint_6" joint="joint_6" kp="200" ctrlrange="-3.1416 3.1416"/>

  <!-- GRIPPER -->
  <position name="pos_left_finger"  joint="left_finger_joint"  kp="50" ctrlrange="0 0.03"/>
  <position name="pos_right_finger" joint="right_finger_joint" kp="50" ctrlrange="0 0.03"/>

  <!-- RUEDAS MOTRICES — diff_drive_controller controla drive_l_2 y drive_r_2 -->
  <velocity name="vel_drive_l_1" joint="drive_l_1" kv="5" ctrlrange="-20 20"/>
  <velocity name="vel_drive_l_2" joint="drive_l_2" kv="5" ctrlrange="-20 20"/>
  <velocity name="vel_drive_l_3" joint="drive_l_3" kv="5" ctrlrange="-20 20"/>
  <velocity name="vel_drive_r_1" joint="drive_r_1" kv="5" ctrlrange="-20 20"/>
  <velocity name="vel_drive_r_2" joint="drive_r_2" kv="5" ctrlrange="-20 20"/>
  <velocity name="vel_drive_r_3" joint="drive_r_3" kv="5" ctrlrange="-20 20"/>

  <!-- RUEDAS DE FLIPPERS -->
  <velocity name="vel_flip1_back"  joint="drive_flip1_back"  kv="5" ctrlrange="-1 1"/>
  <velocity name="vel_flip1_front" joint="drive_flip1_front" kv="5" ctrlrange="-1 1"/>
  <velocity name="vel_flip2_back"  joint="drive_flip2_back"  kv="5" ctrlrange="-1 1"/>
  <velocity name="vel_flip2_front" joint="drive_flip2_front" kv="5" ctrlrange="-1 1"/>
  <velocity name="vel_flip3_back"  joint="drive_flip3_back"  kv="5" ctrlrange="-1 1"/>
  <velocity name="vel_flip3_front" joint="drive_flip3_front" kv="5" ctrlrange="-1 1"/>
  <velocity name="vel_flip4_back"  joint="drive_flip4_back"  kv="5" ctrlrange="-1 1"/>
  <velocity name="vel_flip4_front" joint="drive_flip4_front" kv="5" ctrlrange="-1 1"/>

  <!-- LIDAR — giro continuo a velocidad constante -->
  <velocity name="vel_lidar_spin" joint="lidar_spin" kv="10" ctrlrange="-100 100"/>
</actuator>

<sensor>
  <!-- 7 rayos verticales del LiDAR rotatorio (ambiente A) -->
  <rangefinder name="lidar_0" site="ray_0" cutoff="15.0" noise="0.02"/>
  <rangefinder name="lidar_1" site="ray_1" cutoff="15.0" noise="0.02"/>
  <rangefinder name="lidar_2" site="ray_2" cutoff="15.0" noise="0.02"/>
  <rangefinder name="lidar_3" site="ray_3" cutoff="15.0" noise="0.02"/>
  <rangefinder name="lidar_4" site="ray_4" cutoff="15.0" noise="0.02"/>
  <rangefinder name="lidar_5" site="ray_5" cutoff="15.0" noise="0.02"/>
  <rangefinder name="lidar_6" site="ray_6" cutoff="15.0" noise="0.02"/>
</sensor>
