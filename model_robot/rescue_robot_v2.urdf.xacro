<?xml version="1.0"?>
<robot name="rescue_robot" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- ================= DIMENSIONES ================= -->
  <xacro:property name="H_BASE" value="0.15830"/>
  <xacro:property name="OFF_SHOULDER" value="0.10030"/>
  <xacro:property name="L_UPPER" value="0.35316"/>
  <xacro:property name="OFF_ELBOW" value="-0.10030"/>
  <xacro:property name="L_FORE" value="0.46600"/>
  <xacro:property name="L_WRIST1" value="0.07400"/>
  <xacro:property name="L_WRIST_END" value="0.09350"/>
  <xacro:property name="L_TOOL" value="0.28450"/>
  <xacro:property name="L_TOOL_END" value="${L_TOOL-L_WRIST_END}"/>

  <!-- ================= MATERIALES ================= -->
  <material name="gray"><color rgba="0.7 0.7 0.7 1.0"/></material>
  <material name="orange"><color rgba="1.0 0.4 0.0 1.0"/></material>
  <material name="black"><color rgba="0.2 0.2 0.2 1.0"/></material>
  <material name="silver"><color rgba="0.75 0.75 0.75 1.0"/></material>

  <!-- ================= BASE ROBOT ================= -->
  
  <link name="base_footprint">
    <visual>
      <geometry>
        <box size="0.001 0.001 0.001"/>
      </geometry>
    </visual>
  </link>

  <joint name="base_to_base_footprint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <origin xyz="0 0 -0.03" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="25"/>
      <inertia ixx="1.238151" iyy="1.620218" izz="2.702376" ixy="0.0" iyz="-0.0" ixz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0.55 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://aesir_robot_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 0.55 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://aesir_robot_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="tracked_1_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="3.5"/>
      <inertia ixx="0.064824" iyy="0.377269" izz="0.351452" ixy="0.0" iyz="-0.0" ixz="-0.0"/>
    </inertial>
    <visual>
      <origin xyz="0.24 0.806 -0.06" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://aesir_robot_description/meshes/tracked_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0.24 0.806 -0.06" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://aesir_robot_description/meshes/tracked_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="tracked_2_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="3.5"/>
      <inertia ixx="0.064824" iyy="0.377269" izz="0.351452" ixy="0.0" iyz="0.0" ixz="-0.0"/>
    </inertial>
    <visual>
      <origin xyz="0.24 0.306 -0.06" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://aesir_robot_description/meshes/tracked_2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0.24 0.306 -0.06" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://aesir_robot_description/meshes/tracked_2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- ================= SENSORS ================= -->
  <link name="lidar_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://aesir_robot_description/meshes/lidar.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://aesir_robot_description/meshes/lidar.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.320 0 0.105" rpy="0 0.785398 0"/> 
  </joint>

  <link name="oakd_link">
    <visual>
      <geometry>
        <box size="0.02 0.1 0.03"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.02 0.1 0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="oakd_joint" type="fixed">
    <parent link="base_link"/>
    <child link="oakd_link"/>
    <origin xyz="0.257 0 0.17" rpy="0 0 0"/>
  </joint>

  <link name="arm_camera_link">
    <visual>
      <origin rpy="0 0 -1.5708" xyz="0.02 0.04 -0.2"/>
      <geometry>
        <mesh filename="package://aesir_robot_description/meshes/logitech_c920.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="0 0 -1.5708" xyz="0.02 0.04 -0.2"/>
      <geometry>
        <mesh filename="package://aesir_robot_description/meshes/logitech_c920.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="arm_camera_joint" type="fixed">
    <parent link="link_6"/>
    <child link="arm_camera_link"/>
    <origin xyz="0 0 0.06" rpy="-0.174533 0 0"/>
  </joint>

  <link name="back_camera_link">
    <visual>
      <origin rpy="0 0 3.14159" xyz="0.04 -0.027 -0.19"/>
      <geometry>
        <mesh filename="package://aesir_robot_description/meshes/logitech_c920.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="0 0 3.14159" xyz="0.04 -0.027 -0.19"/>
      <geometry>
        <mesh filename="package://aesir_robot_description/meshes/logitech_c920.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="back_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="back_camera_link"/>
    <origin xyz="-0.30 0 0.17" rpy="0 0 3.14159"/>
  </joint>

  <!-- ================= FLIPPER 1 ================= -->
  <link name="flipper_1_link">
    <inertial>
      <origin xyz="5.551115123125783e-17 0.003554085914685201 0.15154044804505273" rpy="0 0 0"/>
      <mass value="3.742066453745571"/>
      <inertia ixx="0.065573" iyy="0.072966" izz="0.008972" ixy="0.0" iyz="-0.00082" ixz="-0.0"/>
    </inertial>
    <visual>
      <origin xyz="0.24 0.276 -0.06" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://aesir_robot_description/meshes/flipper_1_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0.24 0.276 -0.06" rpy="0 0 3.14159"/>
      <geometry>
        <mesh filename="package://aesir_robot_description/meshes/flipper_1_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- ================= FLIPPER 2 ================= -->
  <link name="flipper_2_link">
    <inertial>
      <origin xyz="-2.7755575615628914e-17 -0.0035540859146853676 0.15154044804505265" rpy="0 0 0"/>
      <mass value="3.7420664537455717"/>
      <inertia ixx="0.065573" iyy="0.072966" izz="0.008972" ixy="0.0" iyz="0.00082" ixz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="-0.24 0.276 -0.06" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://aesir_robot_description/meshes/flipper_4_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="-0.24 0.276 -0.06" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://aesir_robot_description/meshes/flipper_4_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- ================= FLIPPER 3 ================= -->
  <link name="flipper_3_link">
    <inertial>
      <origin xyz="5.551115123125783e-17 -0.0035540859146853676 0.15154044804505276" rpy="0 0 0"/>
      <mass value="3.7420664537455717"/>
      <inertia ixx="0.065573" iyy="0.072966" izz="0.008972" ixy="-0.0" iyz="0.00082" ixz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0.24 0.276 -0.06" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://aesir_robot_description/meshes/flipper_3_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0.24 0.276 -0.06" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://aesir_robot_description/meshes/flipper_3_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- ================= FLIPPER 4 ================= -->
  <link name="flipper_4_link">
    <inertial>
      <origin xyz="-2.7755575615628914e-17 -0.0035540859146853676 0.15154044804505265" rpy="0 0 0"/>
      <mass value="3.7420664537455717"/>
      <inertia ixx="0.065573" iyy="0.072966" izz="0.008972" ixy="0.0" iyz="0.00082" ixz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="-0.24 0.276 -0.06" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://aesir_robot_description/meshes/flipper_4_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="-0.24 0.276 -0.06" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://aesir_robot_description/meshes/flipper_4_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- ================= JOINTS BASE AND FLIPPERS ================= -->

  <joint name="Rigid 1" type="fixed">
    <origin xyz="-0.24 -0.256 0.06" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="tracked_1_link"/>
  </joint>

  <joint name="Rigid 2" type="fixed">
    <origin xyz="-0.24 0.256 0.06" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="tracked_2_link"/>
  </joint>

  <joint name="flipper_joint_1" type="continuous">
    <origin xyz="-0.24 -0.256 0.06" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="flipper_1_link"/>
    <axis xyz="0.0 -1.0 0.0"/>
  </joint>

  <joint name="flipper_joint_2" type="continuous">
    <origin xyz="0.24 -0.256 0.06" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="flipper_2_link"/>
    <axis xyz="0.0 -1.0 0.0"/>
  </joint>

  <joint name="flipper_joint_3" type="continuous">
    <origin xyz="0.24 0.256 0.06" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="flipper_4_link"/>
    <axis xyz="0.0 1.0 0.0"/>
  </joint>

  <joint name="flipper_joint_4" type="continuous">
    <origin xyz="-0.24 0.256 0.06" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="flipper_3_link"/>
    <axis xyz="0.0 1.0 0.0"/>
  </joint>

  <!-- ================= BASE ARM ================= -->
  <joint name="arm_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_base_link"/>
    <origin xyz="0.12 0 0.06" rpy="0 0 0"/> 
  </joint>

  <link name="arm_base_link">
    <visual>
      <origin xyz="0 0 ${H_BASE/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="0.06" length="${H_BASE}"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${H_BASE/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="0.06" length="${H_BASE}"/></geometry>
    </collision>
  </link>

  <!-- ================= JOINT 1 ================= -->
  <joint name="joint_1" type="revolute">
    <parent link="arm_base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 ${H_BASE}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="150.0" velocity="3.14"/>
  </joint>

  <link name="link_1">
    <visual>
      <origin xyz="0 ${OFF_SHOULDER/2} 0" rpy="${pi/2} 0 0"/>
      <geometry><cylinder radius="0.05" length="${OFF_SHOULDER}"/></geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 ${OFF_SHOULDER/2} 0" rpy="${pi/2} 0 0"/>
      <geometry><cylinder radius="0.05" length="${OFF_SHOULDER}"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0"
              iyy="0.01" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <!-- ================= JOINT 2 ================= -->
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 ${OFF_SHOULDER} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="150.0" velocity="3.14"/>
  </joint>

  <link name="link_2">
    <visual>
      <origin xyz="${L_UPPER/2} 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="0.035" length="${L_UPPER}"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="${L_UPPER/2} 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="0.035" length="${L_UPPER}"/></geometry>
    </collision>
    <visual>
      <origin xyz="${L_UPPER} ${OFF_ELBOW/2} 0" rpy="${pi/2} 0 0"/>
      <geometry><cylinder radius="0.04" length="${-OFF_ELBOW}"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="${L_UPPER} ${OFF_ELBOW/2} 0" rpy="${pi/2} 0 0"/>
      <geometry><cylinder radius="0.04" length="${-OFF_ELBOW}"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0"
              iyy="0.01" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <!-- ================= JOINT 3 ================= -->
  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="${L_UPPER} ${OFF_ELBOW} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="150.0" velocity="3.14"/>
  </joint>

  <link name="link_3">
    <visual>
      <origin xyz="${L_FORE/2} 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="0.03" length="${L_FORE}"/></geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="${L_FORE/2} 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="0.03" length="${L_FORE}"/></geometry>
    </collision>
    <visual>
      <origin xyz="${L_FORE} ${L_WRIST1/2} 0" rpy="${pi/2} 0 0"/>
      <geometry><cylinder radius="0.03" length="${L_WRIST1}"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="${L_FORE} ${L_WRIST1/2} 0" rpy="${pi/2} 0 0"/>
      <geometry><cylinder radius="0.03" length="${L_WRIST1}"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0"
              iyy="0.01" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <!-- ================= JOINT 4 ================= -->
  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="${L_FORE} ${L_WRIST1} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="50.0" velocity="3.14"/>
  </joint>

  <link name="link_4">
    <visual>
      <origin xyz="${L_WRIST_END/2} 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="0.025" length="${L_WRIST_END}"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="${L_WRIST_END/2} 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="0.025" length="${L_WRIST_END}"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0"
              iyy="0.01" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <!-- ================= JOINT 5 ================= -->
  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin xyz="${L_WRIST_END} 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="50.0" velocity="3.14"/>
  </joint>

  <link name="link_5">
    <visual>
      <origin xyz="0 ${L_WRIST_END/2} 0" rpy="${pi/2} 0 0"/>
      <geometry><cylinder radius="0.025" length="${L_WRIST_END}"/></geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 ${L_WRIST_END/2} 0" rpy="${pi/2} 0 0"/>
      <geometry><cylinder radius="0.025" length="${L_WRIST_END}"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0"
              iyy="0.01" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <!-- ================= JOINT 6 ================= -->
  <joint name="joint_6" type="revolute">
    <parent link="link_5"/>
    <child link="link_6"/>
    <origin xyz="0 ${L_WRIST_END} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="50.0" velocity="3.14"/>
  </joint>

  <link name="link_6">
    <visual>
      <origin xyz="0 0 0" rpy="${-pi/2} 0 0"/>
      <geometry><cylinder radius="0.01" length="0"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${-pi/2} 0 0"/>
      <geometry><cylinder radius="0.01" length="0"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0"
              iyy="0.01" iyz="0" izz="0.005"/>
    </inertial>
  </link>

    <!-- ================= GRIPPER ================= -->

  <link name="gripper_base_link">
    <visual>
      <origin xyz="0 0.02 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.04 0.06"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0.02 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.04 0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="gripper_mount_joint" type="fixed">
    <parent link="link_6"/>
    <child link="gripper_base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="left_finger_link">
    <visual>
      <origin xyz="0 0.04 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.08 0.02"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0.04 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.08 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

