<?xml version="1.0"?>
<robot name="custom_arm" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- ================= DIMENSIONES ================= -->
  <xacro:property name="H_BASE" value="0.15830"/>
  <xacro:property name="OFF_SHOULDER" value="0.10030"/>
  <xacro:property name="L_UPPER" value="0.35316"/>
  <xacro:property name="OFF_ELBOW" value="-0.10030"/>
  <xacro:property name="L_FORE" value="0.46600"/>
  <xacro:property name="L_WRIST1" value="0.07400"/>
  <xacro:property name="L_WRIST_END" value="0.09350"/>
  <xacro:property name="L_TOOL" value="0.28450"/>

  <!-- ================= MATERIALES ================= -->
  <material name="gray"><color rgba="0.7 0.7 0.7 1.0"/></material>
  <material name="orange"><color rgba="1.0 0.4 0.0 1.0"/></material>
  <material name="black"><color rgba="0.2 0.2 0.2 1.0"/></material>

  <!-- ================= BASE ================= -->
  <link name="world">
    <visual>
      <geometry>
        <box size="0.001 0.001 0.001"/>
      </geometry>
    </visual>
  </link>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${H_BASE/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="0.06" length="${H_BASE}"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${H_BASE/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="0.06" length="${H_BASE}"/></geometry>
    </collision>
  </link>

  <!-- ================= JOINT 1 ================= -->
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 ${H_BASE}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="150.0" velocity="3.14"/>
  </joint>

  <link name="link_1">
    <visual>
      <origin xyz="0 ${OFF_SHOULDER/2} 0" rpy="${pi/2} 0 0"/>
      <geometry><cylinder radius="0.05" length="${OFF_SHOULDER}"/></geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 ${OFF_SHOULDER/2} 0" rpy="${pi/2} 0 0"/>
      <geometry><cylinder radius="0.05" length="${OFF_SHOULDER}"/></geometry>
    </collision>
  </link>

  <!-- ================= JOINT 2 ================= -->
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 ${OFF_SHOULDER} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="150.0" velocity="3.14"/>
  </joint>

  <link name="link_2">
    <visual>
      <origin xyz="${L_UPPER/2} 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="0.035" length="${L_UPPER}"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="${L_UPPER/2} 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="0.035" length="${L_UPPER}"/></geometry>
    </collision>
    <visual>
      <origin xyz="${L_UPPER} ${OFF_ELBOW/2} 0" rpy="${pi/2} 0 0"/>
      <geometry><cylinder radius="0.04" length="${-OFF_ELBOW}"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="${L_UPPER} ${OFF_ELBOW/2} 0" rpy="${pi/2} 0 0"/>
      <geometry><cylinder radius="0.04" length="${-OFF_ELBOW}"/></geometry>
    </collision>
  </link>

  <!-- ================= JOINT 3 ================= -->
  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="${L_UPPER} ${OFF_ELBOW} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="150.0" velocity="3.14"/>
  </joint>

  <link name="link_3">
    <visual>
      <origin xyz="${L_FORE/2} 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="0.03" length="${L_FORE}"/></geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="${L_FORE/2} 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="0.03" length="${L_FORE}"/></geometry>
    </collision>
    <visual>
      <origin xyz="${L_FORE} ${L_WRIST1/2} 0" rpy="${pi/2} 0 0"/>
      <geometry><cylinder radius="0.03" length="${L_WRIST1}"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="${L_FORE} ${L_WRIST1/2} 0" rpy="${pi/2} 0 0"/>
      <geometry><cylinder radius="0.03" length="${L_WRIST1}"/></geometry>
    </collision>
  </link>

  <!-- ================= JOINT 4 ================= -->
  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="${L_FORE} ${L_WRIST1} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="50.0" velocity="3.14"/>
  </joint>

  <link name="link_4">
    <visual>
      <origin xyz="${L_WRIST_END/2} 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="0.025" length="${L_WRIST_END}"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="${L_WRIST_END/2} 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="0.025" length="${L_WRIST_END}"/></geometry>
    </collision>
  </link>

  <!-- ================= JOINT 5 ================= -->
  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin xyz="${L_WRIST1} 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="50.0" velocity="3.14"/>
  </joint>

  <link name="link_5">
    <visual>
      <origin xyz="0 ${L_WRIST_END/2} 0" rpy="${pi/2} 0 0"/>
      <geometry><cylinder radius="0.025" length="${L_WRIST_END}"/></geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 ${L_WRIST_END/2} 0" rpy="${pi/2} 0 0"/>
      <geometry><cylinder radius="0.025" length="${L_WRIST_END}"/></geometry>
    </collision>
  </link>

  <!-- ================= JOINT 6 ================= -->
  <joint name="joint_6" type="revolute">
    <parent link="link_5"/>
    <child link="link_6"/>
    <origin xyz="0 ${L_WRIST_END} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="50.0" velocity="3.14"/>
  </joint>

  <link name="link_6">
    <visual>
      <origin xyz="0 ${L_TOOL/2} 0" rpy="${-pi/2} 0 0"/>
      <geometry><cylinder radius="0.01" length="${L_TOOL}"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 ${L_TOOL/2} 0" rpy="${-pi/2} 0 0"/>
      <geometry><cylinder radius="0.01" length="${L_TOOL-L_WRIST_END}"/></geometry>
    </collision>
  </link>

  <!-- TOOL -->
  <joint name="joint_tool" type="fixed">
    <parent link="link_6"/>
    <child link="tool_link"/>
    <origin xyz="0 ${L_TOOL} 0" rpy="0 0 0"/>
  </joint>
  
  <link name="tool_link">
    <visual>
      <geometry>
        <box size="0.001 0.001 0.001"/>
      </geometry>
    </visual>
  </link>

</robot>