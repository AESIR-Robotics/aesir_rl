<mujoco model="aesir_mapa_completo">

  <asset>
    <texture name="texplane" type="2d" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 0.15 0.2" width="512" height="512"/>
    <material name="matplane" reflectance="0.3" texture="texplane" texrepeat="4 4" texuniform="true"/>
    
    <material name="matdoor" rgba="0.6 0.5 0.4 1"/>
    <material name="mathandle" rgba="1 0.8 0 1"/>

    <mesh name="pallets_mesh" file="meshes/pallets/base_link.stl" scale="0.001 0.001 0.001"/>
    <mesh name="puerta_marco" file="meshes/puerta/base_link.stl" scale="0.001 0.001 0.001"/>
    <mesh name="puerta_hoja"  file="meshes/puerta/puerta_1.stl"  scale="0.001 0.001 0.001"/>
    <mesh name="puerta_manija" file="meshes/puerta/manija_1.stl" scale="0.001 0.001 0.001"/>
  </asset>

  <worldbody>
    <light directional="true" pos="0 0 5" dir="0 0 -1"/>
    
    <geom name="suelo_penalizacion" type="plane" size="50 50 0.1" pos="0 0 0" material="matplane"/>

    <body name="pallets_mesh_body" pos="3 -3.49 0">
      <geom name="pallets_visual" type="mesh" mesh="pallets_mesh" contype="0" conaffinity="0" rgba="0.55 0.38 0.18 1"/>
    </body>

    <body name="door_frame" pos="3.7 -2 0.08">
      <geom type="mesh" mesh="puerta_marco" contype="0" conaffinity="0"/>

      <body name="door_leaf" pos="0 1.05 0.01">
        <joint name="door_hinge" type="hinge" axis="0 0 1" pos="0 0 0" range="-1.5 1.5" damping="3.0"/>
        <geom name="dl_mesh" type="mesh" mesh="puerta_hoja" pos="0 -1.05 -0.009" material="matdoor" contype="0" conaffinity="0"/>

        <body name="door_handle" pos="0.0 -1.32 -1.06">
          <joint name="handle_hinge" type="hinge" axis="1 0 0" pos="0 0.554 2.103" range="-1.0 0.0" damping="0.3" stiffness="2.0"/>
          <geom name="dh_mesh" type="mesh" mesh="puerta_manija" pos="-0.01 0.27 1.05" material="mathandle" contype="0" conaffinity="0"/>
        </body>
      </body>
    </body>

  </worldbody>
</mujoco>